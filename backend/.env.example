# =============================================================================
# TatVivah Backend — Environment Variables
#
# Copy to `.env` and fill in real values:   cp .env.example .env
# Never commit `.env` — it is gitignored.
#
# Validated on boot by src/config/env.ts. Anything marked REQUIRED will
# prevent the server from starting if missing or malformed.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development                  # development | production | test
PORT=3000

# Number of proxy hops to trust (Render/Vercel sit behind one).
TRUST_PROXY=1

# HTTP tuning — safe to leave at defaults.
KEEP_ALIVE_TIMEOUT_MS=65000
HEADERS_TIMEOUT_MS=70000
REQUEST_TIMEOUT_MS=120000
JSON_BODY_LIMIT=5mb
URLENCODED_BODY_LIMIT=5mb
MAX_REQUESTS_PER_SOCKET=1000

# Run cron/queue jobs in this process. Leave unset on the API instance if you
# run a dedicated worker (npm run start:worker).
# RUN_BACKGROUND_JOBS=true

# Keeps a free-tier instance from sleeping by self-pinging.
# BACKEND_WARMUP_URL=https://your-backend.onrender.com/health/live
BACKEND_WARMUP_INTERVAL_MS=240000

# Log every Prisma query (noisy — development only).
PRISMA_LOG_QUERIES=false

# -----------------------------------------------------------------------------
# Database (REQUIRED)
# -----------------------------------------------------------------------------
# Pooled connection string used by the app.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Direct (non-pooled) connection. Needed by some migration workflows.
# DATABASE_URL_DIRECT="postgresql://user:password@host/dbname?sslmode=require"

# -----------------------------------------------------------------------------
# JWT (REQUIRED — each must be at least 32 characters)
# -----------------------------------------------------------------------------
# Generate with:  openssl rand -base64 48
JWT_ACCESS_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string-32

# How long tokens stay valid. Short access tokens + refresh rotation.
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=7d

# -----------------------------------------------------------------------------
# Portal URLs
# -----------------------------------------------------------------------------
# Storefront origin. Used for email CTA links AND as the redirect target for
# hosted-checkout providers, so keep it exact (include www if that's canonical).
FRONTEND_BASE_URL=https://www.tatvivahtrends.com
SELLER_BASE_URL=https://seller.tatvivahtrends.com

# Public URL of THIS backend. Required for GoKwik webhooks.
BACKEND_PUBLIC_URL=https://your-backend.onrender.com

# Next.js on-demand revalidation hook (optional).
# FRONTEND_REVALIDATE_URL=https://www.tatvivahtrends.com/api/revalidate
# FRONTEND_REVALIDATE_SECRET=shared-secret-with-frontend

# Redis pub/sub channel for live UI freshness events.
LIVE_EVENTS_CHANNEL=tatvivah:live-events

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Used for caching, rate limits, and BullMQ queues.
REDIS_URL=redis://default:password@host:6379

# Legacy Upstash REST vars — optional, kept for backwards compatibility.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# -----------------------------------------------------------------------------
# Email — Resend (REQUIRED)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=onboarding@tatvivahtrends.com

# -----------------------------------------------------------------------------
# Fast2SMS — WhatsApp OTP delivery
# -----------------------------------------------------------------------------
# Optional. Without it, OTP delivery falls back / is skipped in development.
# FAST2SMS_API_KEY=your-fast2sms-api-key
FAST2SMS_WHATSAPP_URL=https://www.fast2sms.com/dev/whatsapp
# FAST2SMS_WHATSAPP_MESSAGE_ID=
# FAST2SMS_WHATSAPP_PHONE_NUMBER_ID=

# -----------------------------------------------------------------------------
# ImageKit — product media CDN
# -----------------------------------------------------------------------------
# IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxxxxxx
# IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxxxxx
# IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# -----------------------------------------------------------------------------
# FASHN — virtual try-on
# -----------------------------------------------------------------------------
# FASHN_API_KEY=fa-xxxxxxxxxxxx
FASHN_TRYON_MODEL=tryon-max           # tryon-max | tryon-v1.6
FASHN_POLL_INTERVAL_MS=3000
FASHN_POLL_TIMEOUT_MS=115000

# =============================================================================
# PAYMENTS
#
# GoKwik is the default option at checkout. Razorpay / PhonePe / COD remain
# available; configure only what you actually use.
# =============================================================================

# -----------------------------------------------------------------------------
# GoKwik — Payment Links API (primary)
# -----------------------------------------------------------------------------
# Credentials are issued by GoKwik during onboarding.
# NOTE: GoKwik is a checkout layer, not a gateway — the underlying PG
# (PhonePe, etc.) is configured in the GoKwik merchant dashboard, not here.
#
# API base URLs (resolved from GOKWIK_ENV, not set directly):
#   SANDBOX    -> https://api-gw-v4.dev.gokwik.io/sandbox
#   PRODUCTION -> https://gkx.gokwik.co
#
# Webhooks: register https://<BACKEND_PUBLIC_URL>/v1/webhooks/gokwik
# GOKWIK_APP_ID=
# GOKWIK_APP_SECRET=
# GOKWIK_MERCHANT_ID=
GOKWIK_ENV=SANDBOX                    # SANDBOX | PRODUCTION
GOKWIK_PAYMENT_MODE=standard          # standard (all methods) | upi-deeplink

# -----------------------------------------------------------------------------
# KwikPass — buyer phone/OTP login (GoKwik)
# -----------------------------------------------------------------------------
# The kpToken is a JWE decrypted server-side with this secret. It differs
# between sandbox and production — GoKwik emails you the production key.
# Buyer-only: sellers/admins always use the password login.
# KWIKPASS_MERCHANT_ID=
# KWIKPASS_JWE_SECRET=

# -----------------------------------------------------------------------------
# Razorpay
# -----------------------------------------------------------------------------
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# PhonePe — Standard Checkout v2
# -----------------------------------------------------------------------------
# The client id prefix indicates the key type; SANDBOX keys will 401 against
# the production host and vice versa.
# PHONEPE_CLIENT_ID=
# PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=SANDBOX                   # SANDBOX | PRODUCTION

# Webhook basic-auth pair — must match what you configure on the PhonePe
# dashboard for https://<BACKEND_PUBLIC_URL>/v1/webhooks/phonepe
# PHONEPE_WEBHOOK_USERNAME=
# PHONEPE_WEBHOOK_PASSWORD=

# Optional overrides for the post-payment redirect target.
# PHONEPE_MOBILE_REDIRECT_URL=        # app deep link; falls back to the web page
# PHONEPE_WEB_REDIRECT_BASE_URL=      # defaults to FRONTEND_BASE_URL
