{
  "name": "tatvivahbackend",
  "version": "1.0.0",
  "description": "Multi Vendor Ecom By NextGen Fusion",
  "license": "ISC",
  "author": "Ritesh, Iqbal",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "predev": "prisma generate",
    "dev": "npm run dev:api",
    "dev:api": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "prestart": "prisma generate",
    "start": "npm run start:api",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "typecheck": "tsc --noEmit",
    "test:auth": "tsx scripts/verify-auth.ts",
    "test:product": "tsx scripts/verify-product.ts",
    "test:all": "tsx scripts/verify-all.ts",
    "test": "npm run test:all",
    "verify:auth": "tsx scripts/verify-auth.ts",
    "verify:product": "tsx scripts/verify-product.ts",
    "verify:cart": "tsx scripts/verify-cart.ts",
    "verify:orders": "tsx scripts/verify-orders.ts",
    "verify:payment": "tsx scripts/verify-payment.ts",
    "verify:shipping": "tsx scripts/verify-shipping.ts",
    "verify:admin": "tsx scripts/verify-admin.ts",
    "verify:notifications": "tsx scripts/verify-notifications.ts",
    "verify:razorpay": "tsx scripts/verify-razorpay.ts",
    "verify:cancellation-race": "tsx scripts/simulate-cancellation-race.ts",
    "verify:return-race": "tsx scripts/simulate-return-race.ts",
    "verify:refund-race": "tsx scripts/simulate-refund-race.ts",
    "verify:all": "tsx scripts/verify-all.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@imagekit/nodejs": "^7.2.1",
    "@prisma/client": "^6.2.1",
    "@scalar/express-api-reference": "^0.8.36",
    "@types/ms": "^2.1.0",
    "@types/pdfkit": "^0.17.5",
    "@upstash/redis": "^1.36.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.67.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "imagekit": "^6.0.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "ms": "^2.1.3",
    "openapi3-ts": "^4.5.0",
    "pdfkit": "^0.17.2",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "razorpay": "^2.9.6",
    "resend": "^6.9.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.7",
    "@types/pino": "^7.0.4",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
