# =============================================================================
# TatVivah Frontend (Next.js) — Environment Variables
#
# Copy to `.env.local` and fill in real values:  cp .env.example .env.local
# Never commit `.env.local` — it is gitignored.
#
# IMPORTANT: anything prefixed NEXT_PUBLIC_ is inlined into the JavaScript
# bundle and is visible to anyone who opens the site. Never put a secret
# behind that prefix — only publishable keys and public URLs.
# =============================================================================

# -----------------------------------------------------------------------------
# API (REQUIRED)
# -----------------------------------------------------------------------------
# Origin of the backend. No trailing slash.
# Local development against a local backend:  http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=https://your-backend.onrender.com

# -----------------------------------------------------------------------------
# Site identity
# -----------------------------------------------------------------------------
# Canonical storefront origin — used for SEO metadata, absolute links, and to
# derive the auth cookie domain. Include `www` if that is the canonical host.
NEXT_PUBLIC_SITE_URL=https://www.tatvivahtrends.com

# Seller portal origin (used for cross-portal redirects).
NEXT_PUBLIC_SELLER_PORTAL_URL=https://seller.tatvivahtrends.com

# Cookie domain shared across subdomains. Leave unset to derive it from
# NEXT_PUBLIC_SITE_URL (recommended). Set without a leading dot, e.g.
# `tatvivahtrends.com`, to share the session with seller/admin subdomains.
# NEXT_PUBLIC_COOKIE_DOMAIN=tatvivahtrends.com

# -----------------------------------------------------------------------------
# Contact details (shown in the UI — public by design)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPPORT_EMAIL=support@tatvivahtrends.com
NEXT_PUBLIC_ONBOARDING_EMAIL=onboarding@tatvivahtrends.com
NEXT_PUBLIC_REFUND_EMAIL=refund@tatvivahtrends.com
NEXT_PUBLIC_SELLER_SUPPORT_EMAIL=onboarding@tatvivahtrends.com
NEXT_PUBLIC_PARTNERSHIP_EMAIL=onboarding@tatvivahtrends.com
NEXT_PUBLIC_SUPPORT_PHONE_DISPLAY=+91-9769659709
NEXT_PUBLIC_SUPPORT_PHONE_DIAL=+919769659709

# -----------------------------------------------------------------------------
# ImageKit — seller product image uploads
# -----------------------------------------------------------------------------
# Only the PUBLIC key belongs here. The private key stays on the backend;
# uploads are signed server-side via the backend's ImageKit auth endpoint.
# NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# -----------------------------------------------------------------------------
# KwikPass — buyer phone/OTP login (GoKwik)
# -----------------------------------------------------------------------------
# Merchant ID is public (it identifies the store to GoKwik's browser SDK).
# The JWE secret is NOT set here — it lives on the backend only.
# Leave the merchant id unset to hide the KwikPass login UI entirely.
# NEXT_PUBLIC_KWIKPASS_MERCHANT_ID=
NEXT_PUBLIC_KWIKPASS_ENVIRONMENT=sandbox   # sandbox | production

# -----------------------------------------------------------------------------
# On-demand revalidation (server-only — NOT NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
# Shared secret the backend presents when asking Next.js to revalidate a
# cached page. Must match FRONTEND_REVALIDATE_SECRET on the backend.
# FRONTEND_REVALIDATE_SECRET=shared-secret-with-backend
