# Mobile (Expo) environment (example)
# Copy to mobile/.env and fill in real values.

# Production API base URL
EXPO_PUBLIC_API_BASE_URL=https://your-backend-host
BACKEND_URL=https://your-backend-host
EXPO_PUBLIC_USE_LOCAL_BACKEND=false
USE_LOCAL_BACKEND=false

# ImageKit public key used by Expo client uploads.
# The matching private key must stay only in backend/.env.
EXPO_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_...

# Optional local/dev API base URL (used only when USE_LOCAL_BACKEND=true)
EXPO_PUBLIC_LOCAL_BACKEND_URL=http://localhost:5005
LOCAL_BACKEND_URL=http://localhost:5005
