{
  "expo": {
    "name": "TatVivah",
    "slug": "tatvivah",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow TatVivah to convert your speech into search text.",
        "NSMicrophoneUsageDescription": "Allow TatVivah to use your microphone for voice search."
      }
    },
    "android": {
      "versionCode": 7,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.zaheen.iqbal.mobile",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#B7956C"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TatVivah to select a photo for virtual try-on and product reviews.",
          "cameraPermission": "Allow TatVivah to take a photo for virtual try-on.",
          "microphonePermission": "Allow TatVivah to record audio when capturing media."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow TatVivah to use your microphone for voice search.",
          "speechRecognitionPermission": "Allow TatVivah to convert your speech into search text.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          }
        }
      ],
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "8326af89-8dde-446c-9b49-049a0aff7bb5"
      }
    }
  }
}
